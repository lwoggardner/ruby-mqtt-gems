                "content": [
                  {
                    "Text": "\n# block sent to #each can exit the enumeration via normal break\nsub.each do |topic, payload|\n  break if payload == 'offline'\n  process(topic, payload)\nend\n# blocked here until receive an 'offline' message.\n\n# Enumerable methods return results immediately\nsub.take(5)  # => Array of 5 messages\nsub.first    # => First message [topic, payload, attrs]"
                  }
                ],
                "status": "Success"
              }
            ]
          }
        },
