                "path": "/home/ggardner/workspace-ruby/async-mqtt/.github/workflows/build.yml",
                "new_str": "    - name: Clean stale gems from cache\n      run: bundle clean\n    \n    - name: Generate mosquitto password file\n      run: |\n        docker run --rm -v $PWD/spec/fixture/mosquitto:/mosquitto/config eclipse-mosquitto:latest mosquitto_passwd -b -c /mosquitto/config/passwd ro readonly\n        chmod 644 spec/fixture/mosquitto/passwd\n    \n    - name: Run build (rubocop, docs, tests with broker)\n      run: bundle exec rake",
                "old_str": "    - name: Clean stale gems from cache\n      run: bundle clean\n    \n    - name: Run build (rubocop, docs, tests with broker)\n      run: bundle exec rake",
