                "command": "cd /home/ggardner/workspace-ruby/async-mqtt && source ~/.rvm/scripts/rvm && rvm use 3.4.1 && bundle exec rubocop --debug 2>&1 | grep -i \"inherit\\|require\\|rspec\" | head -20"
              },
              "orig_args": {
                "summary": "Debug what config RuboCop is using",
