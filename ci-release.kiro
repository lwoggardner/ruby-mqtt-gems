        "content": {
          "Prompt": {
            "prompt": "I did this\nOpening in existing browser session.\n✓ Authentication complete.\n- gh config set -h github.com git_protocol https\n✓ Configured git protocol\n✓ Logged in as lwoggardner\n! You were already logged in to this account\n"
