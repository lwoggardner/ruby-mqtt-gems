                "tool_use_id": "tooluse_6cRYvMDhR2uxSBk7Ah9wAg",
                "content": [
                  {
                    "Text": "name: Build\non: \n  push:\n  pull_request:\n  workflow_dispatch:\n    inputs:\n      broker_profile:\n        description: 'Mosquitto broker profile'\n        required: false\n        default: 'testing'\n        type: choice\n        options:\n          - stable\n          - testing\n\njobs:\n  test:\n    strategy:\n      fail-fast: false\n      matrix:\n        os: [ubuntu-latest]\n        ruby: ['3.4']\n    runs-on: ${{ matrix.os }}\n    steps:\n    - uses: actions/checkout@v4\n    \n    - uses: ruby/setup-ruby@v1\n      with:\n        ruby-version: ${{ matrix.ruby }}\n        bundler-cache: true\n    \n    - name: Clean stale gems from cache\n      run: bundle clean\n    \n    - name: Start mosquitto broker\n      run: docker compose --profile ${{ github.event.inputs.broker_profile || 'stable' }} up -d\n    \n    - name: Wait for broker\n      run: sleep 3\n    \n    - name: Run build (rubocop, docs, tests)\n      run: bundle exec rake\n    \n    - name: Stop mosquitto broker\n      if: always()\n      run: docker compose --profile ${{ github.event.inputs.broker_profile || 'stable' }} down"
                  }
                ],
                "status": "Success"
              }
            ]
          }
        },
