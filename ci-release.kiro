              "id": "tooluse_8rdmhrj7THmbDbERcpUMkA",
              "name": "fs_write",
              "orig_name": "fs_write",
              "args": {
                "summary": "Add step to create passwd file before starting broker",
                "path": "/home/ggardner/workspace-ruby/async-mqtt/.github/workflows/build.yml",
                "new_str": "    - name: Clean stale gems from cache\n      run: bundle clean\n    \n    - name: Create mosquitto password file\n      run: |\n        cat > spec/fixture/mosquitto/passwd << 'EOF'\n        ro:$7$101$ECMAPqQehsOgZEcF$2NCVdonAdm7Wk4HMyz28YLxb2q3LDFIpoMWUjEfW8PWB5pOgF4pI0WGvRsyhhgBpeay1vExKKKjLgoG8XlDsWw==\n        samil:$7$101$C2KowExmc6tcaWqP$rLM775Mh8FNDMmUJhLAavtC0iO95REGM+lJ7Kb4Fk0Mz3BWAiHl2y2f/N9tcku0vwm1vV+wSPWqk7QsrCvwrWQ==\n        EOF\n        chmod 600 spec/fixture/mosquitto/passwd\n    \n    - name: Run build (rubocop, docs, tests with broker)\n      run: bundle exec rake",
                "old_str": "    - name: Clean stale gems from cache\n      run: bundle clean\n    \n    - name: Run build (rubocop, docs, tests with broker)\n      run: bundle exec rake",
