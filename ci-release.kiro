                    "Text": "  desc 'Run tests with broker (starts broker, runs tests, stops broker)'\n  task :with_broker do\n    Rake::Task['broker:start'].invoke\n    Rake::Task[:test_all].invoke\n  ensure\n    Rake::Task['broker:stop'].invoke\n  end\n\n  desc 'Run tests assuming broker is already running'\n  task local: :test_all\nend"
                  }
                ],
                "status": "Success"
              }
            ]
          }
        },
