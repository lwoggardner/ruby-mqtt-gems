                "new_str": "    - name: Generate mosquitto password file\n      run: |\n        export MOSQUITTO_UID=$(id -u)\n        export MOSQUITTO_GID=$(id -g)\n        docker run --rm --user $MOSQUITTO_UID:$MOSQUITTO_GID -v $PWD/spec/fixture/mosquitto:/mosquitto/config eclipse-mosquitto:latest mosquitto_passwd -b -c /mosquitto/config/passwd ro readonly\n        ls -la spec/fixture/mosquitto/passwd\n      env:\n        MOSQUITTO_UID: ${{ env.MOSQUITTO_UID }}\n        MOSQUITTO_GID: ${{ env.MOSQUITTO_GID }}\n    \n    - name: Run build (rubocop, docs, tests with broker)\n      run: bundle exec rake\n      env:\n        MOSQUITTO_UID: $(id -u)\n        MOSQUITTO_GID: $(id -g)",
